@model AVSSecurityAuditor.Models.AsvsRequirement
@{
    ViewData["Title"] = "Edit Requirement";
}

<div class="d-flex justify-content-center">
    <div class="w-100" style="max-width:700px;">
        <h2 class="fw-bold mb-4"><i class="fas fa-edit me-2 text-primary"></i>Edit Requirement</h2>
        <div class="card p-4">
            <form asp-action="EditRequirement" method="post">
                @Html.AntiForgeryToken()
                <input type="hidden" name="Id" value="@Model.Id"/>
                <input type="hidden" name="ChapterId" value="@Model.ChapterId"/>
                <div class="row g-3">
                    <div class="col-md-4">
                        <label class="form-label">Requirement ID</label>
                        <input type="text" name="RequirementId" value="@Model.RequirementId" class="form-control" readonly/>
                    </div>
                    <div class="col-md-8">
                        <label class="form-label">Title <span class="text-danger">*</span></label>
                        <input type="text" name="Title" value="@Model.Title" class="form-control" required/>
                    </div>
                    <div class="col-12">
                        <label class="form-label">Description</label>
                        <textarea name="Description" class="form-control" rows="4">@Model.Description</textarea>
                    </div>
                    <div class="col-md-4">
                        <label class="form-label">Level 1</label>
                        <input type="text" name="Level1" value="@Model.Level1" class="form-control" placeholder="✓ or blank"/>
                    </div>
                    <div class="col-md-4">
                        <label class="form-label">Level 2</label>
                        <input type="text" name="Level2" value="@Model.Level2" class="form-control" placeholder="✓ or blank"/>
                    </div>
                    <div class="col-md-4">
                        <label class="form-label">Level 3</label>
                        <input type="text" name="Level3" value="@Model.Level3" class="form-control" placeholder="✓ or blank"/>
                    </div>
                    <div class="col-md-6">
                        <label class="form-label">CWE</label>
                        <input type="text" name="Cwe" value="@Model.Cwe" class="form-control"/>
                    </div>
                    <div class="col-md-6">
                        <label class="form-label">NIST</label>
                        <input type="text" name="Nist" value="@Model.Nist" class="form-control"/>
                    </div>
                </div>
                <div class="d-flex gap-3 mt-4">
                    <button type="submit" class="btn btn-primary px-4">
                        <i class="fas fa-save me-2"></i>Save Changes
                    </button>
                    <a asp-action="Requirements" class="btn btn-outline-secondary">Cancel</a>
                </div>
            </form>
        </div>
    </div>
</div>

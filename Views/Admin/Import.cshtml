@{
    ViewData["Title"] = "Import ASVS CSV";
}

<h2 class="fw-bold mb-4"><i class="fas fa-file-import me-2 text-warning"></i>Import ASVS Checklist</h2>

<div class="row g-4">
    <div class="col-md-7">
        <div class="card p-4">
            <h5 class="fw-bold mb-3">Upload CSV File</h5>
            <form asp-action="Import" method="post" enctype="multipart/form-data">
                @Html.AntiForgeryToken()
                <div class="mb-3">
                    <label class="form-label text-muted">ASVS CSV File</label>
                    <input type="file" name="csvFile" accept=".csv" class="form-control" required />
                    <small class="text-muted mt-1 d-block">
                        Download the official CSV from 
                        <a href="https://github.com/OWASP/ASVS/tree/master/4.0/docs_en" target="_blank" class="text-info">
                            OWASP ASVS GitHub <i class="fas fa-external-link-alt"></i>
                        </a>
                    </small>
                </div>
                <button type="submit" class="btn btn-warning fw-bold px-4">
                    <i class="fas fa-upload me-2"></i>Import CSV
                </button>
            </form>
        </div>

        <div class="card p-4 mt-3">
            <h5 class="fw-bold mb-3">Statistics</h5>
            <div class="row text-center">
                <div class="col">
                    <div class="h3 fw-bold text-primary">@ViewBag.ChapterCount</div>
                    <small class="text-muted">Chapters</small>
                </div>
                <div class="col">
                    <div class="h3 fw-bold text-success">@ViewBag.RequirementCount</div>
                    <small class="text-muted">Requirements</small>
                </div>
            </div>
        </div>
    </div>

    <div class="col-md-5">
        <div class="card p-4">
            <h5 class="fw-bold mb-3"><i class="fas fa-info-circle me-2 text-info"></i>CSV Format</h5>
            <p class="text-muted small">Expected columns in the ASVS CSV:</p>
            <div class="table-responsive">
                <table class="table table-sm">
                    <thead><tr><th>Column</th><th>Description</th></tr></thead>
                    <tbody>
                        <tr><td><code>Chapter</code></td><td>Chapter number (1-14)</td></tr>
                        <tr><td><code>ChapterName</code></td><td>Chapter name</td></tr>
                        <tr><td><code>Req_id</code></td><td>Requirement ID (V1.1.1)</td></tr>
                        <tr><td><code>Item</code></td><td>Requirement title</td></tr>
                        <tr><td><code>Description</code></td><td>Full description</td></tr>
                        <tr><td><code>L1/L2/L3</code></td><td>Security level (✓ or blank)</td></tr>
                        <tr><td><code>CWE</code></td><td>CWE reference</td></tr>
                        <tr><td><code>NIST</code></td><td>NIST reference</td></tr>
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

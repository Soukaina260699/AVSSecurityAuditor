@* Requirements View *@
@model List<AVSSecurityAuditor.Models.AsvsRequirement>
@{
    ViewData["Title"] = "Manage Requirements";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2 class="fw-bold mb-0"><i class="fas fa-database me-2 text-primary"></i>Requirements</h2>
    <span class="badge bg-primary fs-6">@Model.Count total</span>
</div>

<!-- Search & Filter -->
<div class="card p-3 mb-4">
    <form method="get" class="row g-2">
        <div class="col-md-6">
            <input type="text" name="search" value="@ViewBag.Search" class="form-control" placeholder="Search by ID or title..."/>
        </div>
        <div class="col-md-4">
            <select name="chapterId" class="form-select">
                <option value="">All Chapters</option>
                @foreach (var ch in (IEnumerable<AVSSecurityAuditor.Models.AsvsChapter>)ViewBag.Chapters)
                {
                    <option value="@ch.Id" selected="@(ViewBag.ChapterId?.ToString() == ch.Id.ToString())">
                        V@ch.ChapterNumber. @ch.Name
                    </option>
                }
            </select>
        </div>
        <div class="col-md-2">
            <button type="submit" class="btn btn-primary w-100"><i class="fas fa-search"></i></button>
        </div>
    </form>
</div>

<div class="card">
    <div class="table-responsive">
        <table class="table table-hover mb-0">
            <thead>
                <tr>
                    <th>ID</th>
                    <th>Chapter</th>
                    <th>Title</th>
                    <th>Levels</th>
                    <th>CWE</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var r in Model.Take(100))
                {
                    <tr>
                        <td><span class="badge bg-primary">@r.RequirementId</span></td>
                        <td><small class="text-muted">@r.Chapter?.Name</small></td>
                        <td>@r.Title</td>
                        <td>
                            @if (r.Level1 == "✓") { <span class="badge bg-success me-1">L1</span> }
                            @if (r.Level2 == "✓") { <span class="badge bg-warning text-dark me-1">L2</span> }
                            @if (r.Level3 == "✓") { <span class="badge bg-danger">L3</span> }
                        </td>
                        <td><small>@r.Cwe</small></td>
                        <td>
                            <a asp-action="EditRequirement" asp-route-id="@r.Id" class="btn btn-sm btn-outline-primary">
                                <i class="fas fa-edit"></i>
                            </a>
                            <form asp-action="DeleteRequirement" method="post" class="d-inline"
                                  onsubmit="return confirm('Delete this requirement?')">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="id" value="@r.Id"/>
                                <button type="submit" class="btn btn-sm btn-outline-danger">
                                    <i class="fas fa-trash"></i>
                                </button>
                            </form>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
    @if (Model.Count > 100)
    {
        <div class="p-3 text-center text-muted">
            Showing first 100 of @Model.Count results. Use filters to narrow down.
        </div>
    }
</div>

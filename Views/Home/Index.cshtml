@model AVSSecurityAuditor.ViewModels.DashboardViewModel
@{
    ViewData["Title"] = "Dashboard";
}

@if (User.Identity?.IsAuthenticated != true)
{
    <!-- Landing Page for guests -->
    <div class="text-center py-5">
        <div class="mb-4">
            <i class="fas fa-shield-alt" style="font-size:5rem;color:#0d6efd;"></i>
        </div>
        <h1 class="display-4 fw-bold mb-3">ASVS Security Auditor</h1>
        <p class="lead text-muted mb-4">
            Professional OWASP ASVS compliance assessment platform.<br>
            Audit your application security, track compliance, and generate professional reports.
        </p>
        <div class="d-flex gap-3 justify-content-center mb-5">
            <a asp-controller="Account" asp-action="Register" class="btn btn-primary btn-lg px-5">
                <i class="fas fa-rocket me-2"></i>Get Started
            </a>
            <a asp-controller="Checklist" asp-action="Index" class="btn btn-outline-light btn-lg px-5">
                <i class="fas fa-list me-2"></i>View Checklist
            </a>
        </div>
        <div class="row g-4 text-start mt-3">
            <div class="col-md-3">
                <div class="card p-3 h-100">
                    <i class="fas fa-file-import text-primary fa-2x mb-2"></i>
                    <h5>Import ASVS</h5>
                    <p class="text-muted small">Import the official OWASP ASVS CSV checklist with one click.</p>
                </div>
            </div>
            <div class="col-md-3">
                <div class="card p-3 h-100">
                    <i class="fas fa-tasks text-success fa-2x mb-2"></i>
                    <h5>Assess Projects</h5>
                    <p class="text-muted small">Mark each requirement as Valid, Not Valid, N/A, or Pending.</p>
                </div>
            </div>
            <div class="col-md-3">
                <div class="card p-3 h-100">
                    <i class="fas fa-chart-bar text-warning fa-2x mb-2"></i>
                    <h5>Benchmark Reports</h5>
                    <p class="text-muted small">Get compliance percentage, chapter analysis, and risk level.</p>
                </div>
            </div>
            <div class="col-md-3">
                <div class="card p-3 h-100">
                    <i class="fas fa-robot text-info fa-2x mb-2"></i>
                    <h5>AI Assistant</h5>
                    <p class="text-muted small">Ask AI to explain any ASVS requirement with practical examples.</p>
                </div>
            </div>
        </div>
    </div>
}
else
{
    <!-- Authenticated Dashboard -->
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="fw-bold mb-1">Dashboard</h2>
            <p class="text-muted mb-0">Welcome back, @User.Identity!.Name</p>
        </div>
        <a asp-controller="Assessment" asp-action="Create" class="btn btn-primary">
            <i class="fas fa-plus me-2"></i>New Assessment
        </a>
    </div>

    <!-- Stats Cards -->
    <div class="row g-3 mb-4">
        <div class="col-md-3">
            <div class="card p-3">
                <div class="d-flex align-items-center">
                    <div class="rounded-3 p-3 me-3" style="background:rgba(13,110,253,.15);">
                        <i class="fas fa-list text-primary fa-lg"></i>
                    </div>
                    <div>
                        <div class="h3 fw-bold mb-0">@Model.TotalRequirements</div>
                        <div class="text-muted small">ASVS Requirements</div>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card p-3">
                <div class="d-flex align-items-center">
                    <div class="rounded-3 p-3 me-3" style="background:rgba(25,135,84,.15);">
                        <i class="fas fa-folder text-success fa-lg"></i>
                    </div>
                    <div>
                        <div class="h3 fw-bold mb-0">@Model.TotalChapters</div>
                        <div class="text-muted small">Chapters</div>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card p-3">
                <div class="d-flex align-items-center">
                    <div class="rounded-3 p-3 me-3" style="background:rgba(255,193,7,.15);">
                        <i class="fas fa-tasks text-warning fa-lg"></i>
                    </div>
                    <div>
                        <div class="h3 fw-bold mb-0">@Model.TotalAssessments</div>
                        <div class="text-muted small">My Assessments</div>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card p-3">
                <div class="d-flex align-items-center">
                    <div class="rounded-3 p-3 me-3" style="background:rgba(13,202,240,.15);">
                        <i class="fas fa-chart-line text-info fa-lg"></i>
                    </div>
                    <div>
                        <div class="h3 fw-bold mb-0">@Model.AverageCompliance%</div>
                        <div class="text-muted small">Avg Compliance</div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="row g-4">
        <div class="col-md-8">
            <div class="card p-4">
                <h5 class="fw-bold mb-3"><i class="fas fa-history me-2 text-primary"></i>Recent Assessments</h5>
                @if (Model.RecentAssessments.Any())
                {
                    <div class="table-responsive">
                        <table class="table table-hover mb-0">
                            <thead>
                                <tr>
                                    <th>Project</th>
                                    <th>Auditor</th>
                                    <th>Date</th>
                                    <th>Actions</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var a in Model.RecentAssessments)
                                {
                                    <tr>
                                        <td><strong>@a.ProjectName</strong><br><small class="text-muted">@a.Name</small></td>
                                        <td>@a.Auditor</td>
                                        <td><small>@a.CreatedAt.ToString("dd MMM yyyy")</small></td>
                                        <td>
                                            <a asp-controller="Assessment" asp-action="Evaluate" asp-route-id="@a.Id" class="btn btn-sm btn-outline-primary me-1">
                                                <i class="fas fa-edit"></i>
                                            </a>
                                            <a asp-controller="Assessment" asp-action="Report" asp-route-id="@a.Id" class="btn btn-sm btn-outline-success">
                                                <i class="fas fa-chart-bar"></i>
                                            </a>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                    <a asp-controller="Assessment" asp-action="Index" class="btn btn-outline-primary mt-3 btn-sm">
                        View All Assessments →
                    </a>
                }
                else
                {
                    <div class="text-center py-4 text-muted">
                        <i class="fas fa-tasks fa-3x mb-3 opacity-25"></i>
                        <p>No assessments yet.</p>
                        <a asp-controller="Assessment" asp-action="Create" class="btn btn-primary">
                            Create Your First Assessment
                        </a>
                    </div>
                }
            </div>
        </div>
        <div class="col-md-4">
            <div class="card p-4">
                <h5 class="fw-bold mb-3"><i class="fas fa-bolt me-2 text-warning"></i>Quick Actions</h5>
                <div class="d-grid gap-2">
                    <a asp-controller="Assessment" asp-action="Create" class="btn btn-primary">
                        <i class="fas fa-plus me-2"></i>New Assessment
                    </a>
                    <a asp-controller="Checklist" asp-action="Index" class="btn btn-outline-light">
                        <i class="fas fa-list me-2"></i>Browse ASVS Checklist
                    </a>
                    @if (User.IsInRole("Admin"))
                    {
                        <a asp-controller="Admin" asp-action="Import" class="btn btn-outline-warning">
                            <i class="fas fa-file-import me-2"></i>Import CSV
                        </a>
                    }
                </div>
            </div>
            <div class="card p-4 mt-3">
                <h5 class="fw-bold mb-3"><i class="fas fa-info-circle me-2 text-info"></i>About ASVS</h5>
                <p class="text-muted small">
                    The OWASP Application Security Verification Standard (ASVS) provides a basis for testing web application security controls and services.
                </p>
                <a href="https://owasp.org/www-project-application-security-verification-standard/" target="_blank" class="btn btn-sm btn-outline-info">
                    Learn More <i class="fas fa-external-link-alt ms-1"></i>
                </a>
            </div>
        </div>
    </div>
}

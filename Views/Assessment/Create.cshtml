@{
    ViewData["Title"] = "New Assessment";
}

<div class="d-flex justify-content-center">
    <div class="w-100" style="max-width:600px;">
        <h2 class="fw-bold mb-4"><i class="fas fa-plus-circle me-2 text-primary"></i>New Assessment</h2>
        <div class="card p-4">
            <form asp-action="Create" method="post">
                @Html.AntiForgeryToken()
                <div class="mb-3">
                    <label class="form-label fw-bold">Assessment Name <span class="text-danger">*</span></label>
                    <input type="text" name="name" class="form-control" required
                           placeholder="e.g. Q2 2026 Security Audit"/>
                    <small class="text-muted">A descriptive name for this audit session.</small>
                </div>
                <div class="mb-3">
                    <label class="form-label fw-bold">Project / Application Name <span class="text-danger">*</span></label>
                    <input type="text" name="projectName" class="form-control" required
                           placeholder="e.g. E-Commerce Platform v2"/>
                </div>
                <div class="mb-4">
                    <label class="form-label fw-bold">Auditor Name <span class="text-danger">*</span></label>
                    <input type="text" name="auditor" class="form-control" required
                           placeholder="Your name or team name"/>
                </div>
                <div class="d-flex gap-3">
                    <button type="submit" class="btn btn-primary px-4 fw-bold">
                        <i class="fas fa-rocket me-2"></i>Create Assessment
                    </button>
                    <a asp-action="Index" class="btn btn-outline-secondary">Cancel</a>
                </div>
            </form>
        </div>
        <div class="card p-3 mt-3">
            <small class="text-muted">
                <i class="fas fa-info-circle me-2 text-info"></i>
                All ASVS requirements will be pre-loaded as <strong>Pending</strong>.
                You can then evaluate each one chapter by chapter.
            </small>
        </div>
    </div>
</div>
